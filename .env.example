# GitHub token (server-side only - NOT exposed to the browser)
GITHUB_API_TOKEN  # Go to settings -> Developer setting -> Personal Access Token -> Tokens -> Generate New Tokens

# Gemini API key (server-side only)
GEMINI_API_TOKEN  # Get from https://aistudio.google.com/apikey

# Backend URL for local development (defaults to http://localhost:3001)
VITE_BACKEND_URL = http://localhost:3001 